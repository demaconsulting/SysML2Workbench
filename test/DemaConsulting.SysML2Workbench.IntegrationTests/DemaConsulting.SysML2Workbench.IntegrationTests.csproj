<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <RootNamespace>DemaConsulting.SysML2Workbench.IntegrationTests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="4.150.1" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
    <PackageReference Include="Appium.WebDriver" Version="8.3.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Copied alongside the test binaries so a test can resolve an absolute, cwd-independent path via
         AppContext.BaseDirectory when passing it as a "startup-source" argument to AppFixture/StartApp. -->
    <None Include="TestData\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!--
    Deliberately no ProjectReference to src/DemaConsulting.SysML2Workbench: this tier drives the compiled
    Desktop application externally through Appium's WebDriver client rather than in-process, matching
    testing-principles.md's hierarchy-boundary rule for a black-box/system-level test tier.
  -->

</Project>
