<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:DemaConsulting.SysML2Workbench.AppShellSubsystem"
             x:Class="DemaConsulting.SysML2Workbench.App"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <DockFluentTheme />
  </Application.Styles>

</Application>
