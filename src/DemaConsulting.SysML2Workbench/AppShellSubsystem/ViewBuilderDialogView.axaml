<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DemaConsulting.SysML2Workbench.AppShellSubsystem"
        xmlns:picker="using:DemaConsulting.SysML2Workbench.ElementPickerSubsystem"
        x:Class="DemaConsulting.SysML2Workbench.AppShellSubsystem.ViewBuilderDialogView"
        x:DataType="local:ViewBuilderDialogViewModel"
        Title="Custom View Builder"
        Icon="avares://DemaConsulting.SysML2Workbench/Assets/Icon.png"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="12">

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Name="OkButton" Content="OK" IsDefault="True" Click="OnOkButtonClick" MinWidth="80" HorizontalContentAlignment="Center" />
      <Button Name="CancelButton" Content="Cancel" IsCancel="True" Click="OnCancelButtonClick" MinWidth="80" HorizontalContentAlignment="Center" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Name="StatusTextBlock" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="Red" Margin="0,8,0,0" />

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="150" />
        <ColumnDefinition Width="5" />
        <ColumnDefinition Width="*" MinWidth="300" />
      </Grid.ColumnDefinitions>

      <!-- Left: live SVG preview -->
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Background="White">
        <Panel>
          <TextBlock Name="EmptyStateTextBlock" IsVisible="{Binding IsWorkspaceEmpty}" Text="No workspace open - add a file or folder from the Workspace panel." TextWrapping="Wrap" Margin="8" />
          <Image Name="PreviewImage" Stretch="Uniform" Margin="4" />
        </Panel>
      </Border>

      <!-- Draggable splitter between the preview pane and the tabs -->
      <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" ResizeDirection="Columns" Background="Transparent" />

      <!-- Right: view-kind / expose-targets / filter-and-name tabs -->
      <TabControl Grid.Column="2">

        <TabItem Header="View Kind">
          <StackPanel Margin="8" Spacing="6">
            <TextBlock Text="View Kind" />
            <ComboBox Name="ViewKindComboBox" HorizontalAlignment="Stretch" />
          </StackPanel>
        </TabItem>

        <TabItem Header="Expose Targets">
          <ScrollViewer>
            <StackPanel Margin="8" Spacing="6">
              <TextBlock Text="Available (select, then Add)" />

              <picker:ElementPickerView Name="ExposeTargetPickerView" DataContext="{Binding ExposeTargetPicker}" />

              <Button Name="AddExposeTargetButton" Content="Add →" HorizontalAlignment="Stretch" />

              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Selected" />
                <TextBlock Text="&#x24D8;" FontWeight="Bold" Foreground="SteelBlue" Cursor="Hand">
                  <ToolTip.Tip>
                    <StackPanel Spacing="4" MaxWidth="360">
                      <TextBlock Text="Each selected target's recursion kind controls which SysML v2 'expose' textual form is generated and rendered." TextWrapping="Wrap" FontWeight="Bold" />
                      <TextBlock Text="This element only - exposes just the named element (expose Target;)." TextWrapping="Wrap" />
                      <TextBlock Text="This element + everything below (::**) - exposes the element and its full nested membership." TextWrapping="Wrap" />
                      <TextBlock Text="Direct children only (::*) - exposes only the element's immediate namespace members." TextWrapping="Wrap" />
                      <TextBlock Text="All descendants, not itself (::*::**) - exposes every namespace descendant, excluding the element itself." TextWrapping="Wrap" />
                    </StackPanel>
                  </ToolTip.Tip>
                </TextBlock>
              </StackPanel>
              <StackPanel Name="SelectedExposeTargetsPanel" Spacing="4" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Filter &amp; Name">
          <StackPanel Margin="8" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Filter Expression (optional)" />
              <TextBlock Text="&#x24D8;" FontWeight="Bold" Foreground="SteelBlue" Cursor="Hand">
                <ToolTip.Tip>
                  <StackPanel Spacing="4" MaxWidth="360">
                    <TextBlock Text="Narrows the exposed targets to elements matching a SysML v2 filter expression (Phase 1 subset)." TextWrapping="Wrap" FontWeight="Bold" />
                    <TextBlock Text="Supported: classification tests (@Type), boolean connectives (and / or / not / xor / &amp; / |), parentheses, and (as Type).attribute reads compared with == or != against a literal." TextWrapping="Wrap" />
                    <TextBlock Text="Not supported: istype/hastype/all, arithmetic, conditionals, and general feature-chain navigation." TextWrapping="Wrap" FontStyle="Italic" />
                    <TextBlock Text="Examples:" FontWeight="Bold" />
                    <TextBlock Text="@Safety" FontFamily="Consolas" />
                    <TextBlock Text="@Requirements::Verification" FontFamily="Consolas" />
                    <TextBlock Text="not @Deprecated" FontFamily="Consolas" />
                    <TextBlock Text="@Safety and @Critical" FontFamily="Consolas" />
                    <TextBlock Text="@Safety or @Security" FontFamily="Consolas" />
                    <TextBlock Text="(as PartDefinition).name == 'Engine'" FontFamily="Consolas" />
                  </StackPanel>
                </ToolTip.Tip>
              </TextBlock>
            </StackPanel>
            <TextBox Name="FilterExpressionTextBox" PlaceholderText="e.g. @Safety and not @Deprecated" />

            <TextBlock Text="View Name (optional)" />
            <TextBox Name="DisplayNameTextBox" PlaceholderText="CustomView" />
          </StackPanel>
        </TabItem>

      </TabControl>

    </Grid>

  </DockPanel>

</Window>
