<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:dockControls="using:Dock.Model.Mvvm.Controls"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="DemaConsulting.SysML2Workbench.AppShellSubsystem.MainWindowView"
        Title="SysML2Workbench"
        Icon="avares://DemaConsulting.SysML2Workbench/Assets/Icon.png"
        Width="1024" Height="700">

  <DockPanel DragDrop.AllowDrop="True">

    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Name="AddFileSourceMenuItem" Header="Open _File..." AutomationProperties.AutomationId="AddFileSourceMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="FileOutline" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Name="AddFolderSourceMenuItem" Header="Open _Folder..." AutomationProperties.AutomationId="AddFolderSourceMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="FolderOpenOutline" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Name="CloseAllMenuItem" Header="Close _All" Click="OnCloseAllMenuItemClick" AutomationProperties.AutomationId="CloseAllMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="CloseBoxMultipleOutline" />
          </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Name="ExitMenuItem" Header="E_xit" Click="OnExitMenuItemClick" AutomationProperties.AutomationId="ExitMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="ExitToApp" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Name="WorkspacePanelMenuItem" Header="_Workspace" Click="OnWorkspacePanelMenuItemClick" x:DataType="dockControls:Tool" IsChecked="{Binding IsOpen, Mode=OneWay}" AutomationProperties.AutomationId="WorkspacePanelMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="FileTree" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Name="PredefinedViewsMenuItem" Header="_Predefined Views" Click="OnPredefinedViewsMenuItemClick" x:DataType="dockControls:Tool" IsChecked="{Binding IsOpen, Mode=OneWay}" AutomationProperties.AutomationId="PredefinedViewsMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="ViewList" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Name="DiagnosticsMenuItem" Header="_Diagnostics" Click="OnDiagnosticsMenuItemClick" x:DataType="dockControls:Tool" IsChecked="{Binding IsOpen, Mode=OneWay}" AutomationProperties.AutomationId="DiagnosticsMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="AlertCircleOutline" />
          </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Name="ViewBuilderDialogMenuItem" Header="_Custom View Builder..." Click="OnOpenViewBuilderDialogClick" AutomationProperties.AutomationId="ViewBuilderDialogMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="PencilRuler" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Query">
        <MenuItem Name="QueryDialogMenuItem" Header="_Run Query..." Click="OnOpenQueryDialogClick" AutomationProperties.AutomationId="QueryDialogMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="Magnify" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Name="AboutMenuItem" Header="_About" Click="OnAboutMenuItemClick" AutomationProperties.AutomationId="AboutMenuItem">
          <MenuItem.Icon>
            <mi:MaterialIcon Kind="InformationOutline" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
    </Menu>

    <dock:DockControl Name="WorkbenchDockControl" AutomationProperties.AutomationId="WorkbenchDockControl">
      <dock:DockControl.Styles>
        <!--
          The Fluent Dock theme's DocumentControl template unconditionally draws a 1px
          DockDocumentContentBorderBrush/Thickness ring around its content area
          (Dock.Avalonia.Themes.Fluent/Controls/DocumentControl.axaml, Style Selector
          "^/template/ Border#PART_Border"), whether or not the dock has any visible
          document tabs. Headless-rendered pixel capture (test/OtsSoftwareTests/DockTests.cs,
          DiagramDock_EmptyArea_HasNoVisibleBorder) confirmed this same 1px gray ring is drawn
          identically in both states - it is not conditionally hidden or masked by tab content;
          it is simply imperceptible against a busy/opaque diagram once a tab is open, but stands
          out sharply around the otherwise-blank area when zero diagram tabs are open (the
          EmptyContent = null state - see WorkbenchDockFactory.CreateLayout). DocumentControl
          exposes its own "HasVisibleDockables" styled property (bound by the template itself to
          toggle PART_ContentPresenter/PART_EmptyContentHost visibility), which this style reuses
          to zero the border's thickness only when the dock has zero visible documents, leaving
          the with-tab-open appearance completely untouched. Scoped to this single DockControl
          (the only one in the app today, hosting only DiagramDock) rather than the global
          Dock.Avalonia.Themes.Fluent theme dictionary, so it cannot affect any other/future dock.
        -->
        <Style Selector="dock|DocumentControl[HasVisibleDockables=False] /template/ Border#PART_Border">
          <Setter Property="BorderThickness" Value="0" />
        </Style>
      </dock:DockControl.Styles>
    </dock:DockControl>

  </DockPanel>

</Window>
