<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:DemaConsulting.SysML2Workbench.AppShellSubsystem"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="DemaConsulting.SysML2Workbench.AppShellSubsystem.SourceTextDocumentView"
             x:DataType="local:SourceTextDocumentViewModel">

  <ae:TextEditor Name="SourceTextEditor"
                 IsReadOnly="True"
                 ShowLineNumbers="True"
                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />

</UserControl>
